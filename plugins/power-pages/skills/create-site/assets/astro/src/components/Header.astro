---
interface Props {
  currentPath: string
}

const { currentPath } = Astro.props
---

<header class="header">
  <nav class="nav">
    <a href="/" class="logo">__SITE_NAME__</a>
    <div class="nav-links">
      <a href="/" class:list={[{ active: currentPath === '/' }]}>Home</a>
      <a href="/about" class:list={[{ active: currentPath === '/about/' || currentPath === '/about' }]}>About</a>
    </div>
  </nav>
</header>
